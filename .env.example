# Copy this file to .env and adjust values per environment.
# Do not put secrets in this file.

# Application
APP_NAME=AI Ingestion & Retrieval Platform
LOG_LEVEL=INFO

# Metrics endpoint security
METRICS_ENABLED=false
METRICS_TOKEN=change-me

# HTTP client timeouts (seconds)
HTTP_TIMEOUT_CONNECT_SECONDS=2.0
HTTP_TIMEOUT_READ_SECONDS=5.0
HTTP_TIMEOUT_WRITE_SECONDS=5.0
HTTP_TIMEOUT_POOL_SECONDS=2.0

# HTTP client connection pool
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
HTTP_KEEPALIVE_EXPIRY_SECONDS=30.0

# Per-URL timeout safety
URL_TIMEOUT_SECONDS=10.0

# Ingestion limits
MAX_REDIRECTS=5
MAX_PREVIEW_BYTES=65536
MAX_PREVIEW_TEXT_CHARS=500
MAX_BATCH_URLS=20
ALLOWED_FETCH_PORTS=[80,443]

# Ingestion API authentication
INGESTION_AUTH_ENABLED=false
INGESTION_AUTH_TOKEN=change-me

# Parser boundary limits
MAX_PARSE_BYTES=5000000
MAX_PARSED_TEXT_CHARS=100000
MAX_PARSE_PAGES=50
PARSE_TIMEOUT_SECONDS=10.0
ALLOWED_PARSE_CONTENT_TYPES=["text/html","text/plain","application/pdf"]

# Retry policy
RETRY_ATTEMPTS=3
RETRY_TOTAL_TIMEOUT_SECONDS=10.0
RETRY_BACKOFF_INITIAL_SECONDS=0.5
RETRY_BACKOFF_MAX_SECONDS=4.0

# Concurrency controls
DEFAULT_MAX_CONCURRENCY=3
MAX_ALLOWED_CONCURRENCY=10
GLOBAL_MAX_OUTBOUND_FETCHES=24
HOST_MAX_CONCURRENCY=3
HOST_LIMITER_CACHE_SIZE=1024

# Inbound API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_KEY_PREFIX=ai-irp:rate-limit
RATE_LIMIT_FAIL_OPEN=false

# Inbound API rate limits
RATE_LIMIT_URL_PREVIEW_REQUESTS=30
RATE_LIMIT_URL_PREVIEW_WINDOW_SECONDS=60
RATE_LIMIT_BATCH_PREVIEW_REQUESTS=10
RATE_LIMIT_BATCH_PREVIEW_WINDOW_SECONDS=60

# Inbound API rate-limit costs
RATE_LIMIT_URL_PREVIEW_COST=1
RATE_LIMIT_URL_PARSE_PREVIEW_COST=2
RATE_LIMIT_BATCH_PREVIEW_URL_COST=1
RATE_LIMIT_BATCH_PARSE_PREVIEW_URL_COST=2